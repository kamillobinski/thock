#!/bin/bash

# thock-cli (Control Thock from the terminal, scripts, or tools like Raycast)
# Docs: https://github.com/kamillobinski/thock/blob/main/docs/THOCK-CLI.md

# ─── Config ───────────────────────────────────────────────────────────────────

SOUNDPACKS_DIR="$HOME/Library/Application Support/Thock/Soundpacks"
PIPE="$HOME/Library/Application Support/thock/thock.pipe"

# ─── ls ───────────────────────────────────────────────────────────────────────

if [[ "$1" == "ls" ]]; then
  if [[ ! -d "$SOUNDPACKS_DIR" ]]; then
    echo "No soundpacks directory found at: $SOUNDPACKS_DIR"
    exit 0
  fi

  JSON_OUTPUT=false
  [[ "$2" == "--json" ]] && JSON_OUTPUT=true

  python3 - "$SOUNDPACKS_DIR" "$JSON_OUTPUT" <<'EOF'
import json, os, re, sys

directory = sys.argv[1]
as_json = sys.argv[2] == "true"
soundpacks = []

for name in os.listdir(directory):
    config_path = os.path.join(directory, name, "config.json")
    if not os.path.isfile(config_path):
        continue
    with open(config_path) as f:
        raw = re.sub(r",\s*([}\]])", r"\1", f.read())
    try:
        c = json.loads(raw)
        m = c["metadata"]
        soundpacks.append({
            "id": c["id"],
            "name": m["name"],
            "brand": m["brand"],
            "author": m["author"],
            "category": m["category"],
        })
    except (json.JSONDecodeError, KeyError):
        continue

if as_json:
    print(json.dumps(soundpacks, indent=2))
else:
    if not soundpacks:
        print("No soundpacks installed.")
    else:
        by_category = {}
        for s in soundpacks:
            by_category.setdefault(s["category"], []).append(s)

        name_width = max(len(s["name"]) for s in soundpacks)
        author_width = max(len(s["author"]) for s in soundpacks)

        for category, entries in sorted(by_category.items()):
            print(f"{category.capitalize()}")
            for s in sorted(entries, key=lambda x: x["name"]):
                name = s["name"].ljust(name_width)
                author = f"by {s['author']}".ljust(author_width + 3)
                print(f"  {name}  {author}  {s['id']}")
            print()
EOF
  exit 0
fi

# ─── Pipe commands ────────────────────────────────────────────────────────────

if [[ ! -p "$PIPE" ]]; then
  echo "Error: Thock pipe not found at: $PIPE"
  echo "Make sure Thock is running and has created the named pipe."
  exit 1
fi

COMMAND=""
for arg in "$@"; do
  escaped_arg="${arg//\"/\\\"}"
  COMMAND+="\"$escaped_arg\" "
done

echo "${COMMAND%% }" > "$PIPE"
